# ── Wardrobe Starter Kit — environment ───────────────────────────────────
# Copy to .env.local and fill in your own values. Never commit real values.

# Notion internal integration token (starts with "ntn_" or "secret_").
# Create at notion.so/profile/integrations, then SHARE your wardrobe database
# AND your style reference page with this integration.
NOTION_TOKEN=

# Your wardrobe database id (create your own — see README "Set up your Notion").
NOTION_DB_ID=

# The "Assessed Looks" database id (powers the photo-assessment flow).
NOTION_ASSESSED_DB_ID=

# The "Looks / Outfit Diary" database id. Share this DB with the integration too.
NOTION_LOOKS_DB_ID=

# The "Wishlist" database id.
NOTION_WISHLIST_DB_ID=

# Optional: a calendar's "Secret address in iCal format" (Google Calendar → that calendar's
# Settings → Integrate calendar). Powers the Log-a-Look event suggestions. Server-only — this
# URL grants read access to the calendar, so keep it secret. Leave blank to disable.
CALENDAR_ICS_URL=

# Receipt import (/api/inbound-email): the inbound-email provider must send this secret as
# ?secret= or the x-inbound-secret header; the webhook rejects mismatches. Leave blank to
# accept unauthenticated (NOT recommended in production).
INBOUND_EMAIL_SECRET=

# Optional: inbox address shown on the Import page (default closet@example.com).
NEXT_PUBLIC_CLOSET_EMAIL=

# "Find original product image" photo-only path: SerpAPI key for reverse image search (Google
# Lens). The product-link path works without it. Optionally override the endpoint.
SERPAPI_KEY=
REVERSE_IMAGE_API_URL=

# Anthropic API key for the photo assessment (console.anthropic.com).
ANTHROPIC_API_KEY=

# Model used for assessments. Swap if you prefer.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Vercel Blob storage. Powers image uploads: the try-on reference photo, Salon
# results, and your uploaded colour analysis (/palette). Set automatically when
# you add Blob storage to the Vercel project; required for those features.
BLOB_READ_WRITE_TOKEN=

# Salon hair try-on (Replicate FLUX Kontext). Optional — the Salon page needs it
# to render new hair colours/styles. HAIR_MODEL overrides the default model.
REPLICATE_API_TOKEN=
HAIR_MODEL=

# Shared passcode that gates the app (pick anything; share only with people you trust).
APP_PASSCODE=
